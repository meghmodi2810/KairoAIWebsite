# Copy this file to .env and fill in real values (DO NOT commit .env)

# Mailer server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=replace_with_real_smtp_password

# Optional: recipient for contact form notifications. Defaults to SMTP_USER
CONTACT_RECIPIENT=your-email@example.com

# Local mailer server port (used by Vite proxy)
SERVER_PORT=5175
